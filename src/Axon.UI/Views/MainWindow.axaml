<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Axon.UI.ViewModels"
        xmlns:views="using:Axon.UI.Views"
        x:Class="Axon.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Axon — Sovereign Biometric Vault"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        Background="#0F0F1A">

    <!--
        Shell layout:
          Row 0 — global nav / sync status bar
          Row 1 — active content page (expands to fill)

        The MainView (dashboard) is bound to MainWindowViewModel.Dashboard
        so the SkiaTelemetryChart gets its DashboardViewModel DataContext
        without any code-behind coupling.
    -->
    <Grid RowDefinitions="Auto,*">

        <!-- ── Global nav / sync status bar ──────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#13131F"
                BorderBrush="#2D2D4E"
                BorderThickness="0,0,0,1"
                Padding="16,6">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="⬡"
                               FontSize="18" Foreground="#00FFC8"
                               VerticalAlignment="Center" />
                    <TextBlock Text="AXON"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#E5E7EB"
                               VerticalAlignment="Center"
                               LetterSpacing="3" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <Button Content="Dashboard"
                            Command="{Binding ShowDashboardCommand}" />
                    <Button Content="Analysis Lab"
                            Command="{Binding ShowAnalysisLabCommand}" />
                    <Button Content="Settings"
                            Command="{Binding ShowSettingsCommand}" />
                </StackPanel>

                <!-- Sync status indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                    <!-- Air-gap badge -->
                    <Border Background="#1F2937" CornerRadius="6" Padding="8,3"
                            IsVisible="{Binding AirGapEnabled}">
                        <TextBlock Text="AIR-GAP"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#F59E0B"
                                   LetterSpacing="1.5" />
                    </Border>

                    <!-- Pending outbox count -->
                    <Border Background="#1F2937" CornerRadius="6" Padding="8,3"
                            IsVisible="{Binding PendingOutboxCount}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="OUTBOX"
                                       FontSize="10" Foreground="#6B7280"
                                       LetterSpacing="1" />
                            <TextBlock Text="{Binding PendingOutboxCount}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#9CA3AF" />
                        </StackPanel>
                    </Border>

                    <!-- Sync status dot -->
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="#34D399" />
                        </Ellipse.Fill>
                    </Ellipse>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Dashboard content ─────────────────────────────────────────── -->
        <!--
            DataContext is explicitly forwarded to Dashboard so MainView's
            x:DataType="vm:DashboardViewModel" compiled binding resolves correctly.
        -->
        <!--
            Each view's x:DataType causes Avalonia compiled binding to resolve
            attribute bindings against the child ViewModel type, not MainWindowViewModel.
            Fix: IsVisible goes on a wrapper Panel (no x:DataType → inherits MainWindowViewModel);
            DataContext uses ReflectionBinding to bypass compile-time type checking.
        -->
        <Grid Grid.Row="1">
            <Panel IsVisible="{Binding IsDashboardActive}">
                <views:MainView DataContext="{ReflectionBinding Dashboard}" />

                <!-- ── First-run onboarding overlay (rec #1) ─────────────────── -->
                <Border IsVisible="{Binding Dashboard.IsEmptyState}"
                        Background="#F20F0F1A"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <Border Background="#171827"
                            BorderBrush="#2D2D4E"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="40,32"
                            MaxWidth="560"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Welcome to Axon"
                                       FontSize="26" FontWeight="Bold" Foreground="#F8FAFC" />
                            <TextBlock Text="Your private, offline biometric lab. Bring your wearable data into one place, run local AI analysis, and keep full ownership — no account, no cloud."
                                       FontSize="14" Foreground="#B6C2D9" TextWrapping="Wrap" />
                            <TextBlock Text="Get your first insight in two steps:"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,6,0,0" />
                            <StackPanel Spacing="6">
                                <TextBlock Text="1.  Connect Whoop, or import a CSV of past data"
                                           FontSize="13" Foreground="#B6C2D9" />
                                <TextBlock Text="2.  Axon builds your baseline and surfaces anomalies + a recovery outlook"
                                           FontSize="13" Foreground="#B6C2D9" />
                            </StackPanel>
                            <Button Content="Connect a source or import data →"
                                    Command="{Binding ShowSettingsCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Padding="16,10"
                                    Background="#00B894"
                                    Foreground="#0F0F1A"
                                    FontWeight="SemiBold" />
                            <TextBlock Text="Everything stays on this machine. You can export or wipe it any time."
                                       FontSize="11" Foreground="#6B7280" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Border>
            </Panel>
            <Panel IsVisible="{Binding IsAnalysisLabActive}">
                <views:AnalysisLabView DataContext="{ReflectionBinding AnalysisLab}" />
            </Panel>
            <Panel IsVisible="{Binding IsSettingsActive}">
                <views:SettingsView DataContext="{ReflectionBinding Settings}" />
            </Panel>
        </Grid>

    </Grid>
</Window>
