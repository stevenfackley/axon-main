<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Axon.UI.ViewModels"
             x:Class="Axon.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="#0F0F1A">

    <Grid RowDefinitions="Auto,*" Margin="16">
        <TextBlock Grid.Row="0"
                   Text="Sovereign Settings"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#E5E7EB" />

        <Grid Grid.Row="1" Margin="0,16,0,0" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="16">
            <Border Grid.Row="0" Grid.Column="0" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="VAULT" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <TextBlock Text="{Binding VaultType}" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" />
                    <TextBlock Text="{Binding KeyFingerprint}" FontSize="13" Foreground="#94A3B8" />
                    <TextBlock Text="{Binding IsHardwareBacked, StringFormat=Hardware-backed: {0}}" Foreground="#B6C2D9" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="LICENSE" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <TextBlock Text="{Binding LicenseTierText}" FontSize="20" FontWeight="SemiBold" Foreground="#00FFC8" />
                    <TextBlock Text="Free imports &amp; views your data. Pro unlocks automated sync, unlimited history, and the insight engine." Foreground="#94A3B8" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="SYNC" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <TextBlock Text="{Binding PendingOutboxItems}" FontSize="28" FontWeight="Bold" Foreground="#00FFC8" />
                    <TextBlock Text="Pending outbox items" Foreground="#B6C2D9" />
                    <TextBlock Text="{Binding SyncTransportName, StringFormat=Transport: {0}}" Foreground="#94A3B8" />
                    <TextBlock Text="{Binding SyncStatusText, StringFormat=Relay state: {0}}" Foreground="#94A3B8" />
                    <TextBlock Text="{Binding LastSuccessfulSync, StringFormat=Last successful sync: {0:g}}" Foreground="#94A3B8" />
                    <TextBlock Text="{Binding LastSyncError, StringFormat=Last error: {0}}" Foreground="#FCA5A5"
                               IsVisible="{Binding LastSyncError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="AIR-GAP" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <ToggleSwitch IsChecked="{Binding AirGapEnabled}" Content="Disable outbound networking" />
                    <TextBlock Text="When on, every outbound network request is blocked at the HTTP layer — not just paused. Analysis stays fully functional offline." Foreground="#94A3B8" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="OBSERVABILITY" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <ToggleSwitch IsChecked="{Binding TelemetryEnabled}" Content="Enable OpenTelemetry export" />
                    <TextBlock Text="This controls OpenTelemetry exporters for the desktop runtime. The local health report stays available even when export is disabled." Foreground="#94A3B8" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Grid.ColumnSpan="2" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="WHOOP" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <TextBlock Text="{Binding WhoopStatusText}" FontSize="16" FontWeight="SemiBold" Foreground="#F8FAFC" />
                    <TextBlock Text="Connect your Whoop account to sync recovery, sleep, strain, and workout data locally." Foreground="#94A3B8" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Button Content="Connect Whoop" Command="{Binding ConnectWhoopCommand}" />
                        <Button Content="Sync now" Command="{Binding SyncWhoopCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Grid.ColumnSpan="2" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="DATA RESIDENCY" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <TextBlock Text="{Binding DataFootprintText}" FontSize="18" FontWeight="SemiBold" Foreground="#00FFC8" />
                    <TextBlock Text="No account. No cloud. Your biometric data never leaves this machine." Foreground="#B6C2D9" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding DataFolderPath}" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" />
                    <Button Content="Open data folder" Command="{Binding OpenDataFolderCommand}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Grid.ColumnSpan="2" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="IMPORT" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <TextBlock Text="{Binding ImportStatusText}" FontSize="16" FontWeight="SemiBold" Foreground="#F8FAFC" TextWrapping="Wrap" />
                    <TextBlock Text="Load a CSV with columns: timestamp, type, value, unit. Unrecognized rows are skipped." Foreground="#94A3B8" TextWrapping="Wrap" />
                    <Button Content="Import CSV…" Click="OnImportClick" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Grid.ColumnSpan="2" Background="#171827" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="ABOUT" FontSize="10" Foreground="#6B7280" LetterSpacing="1.5" />
                    <TextBlock Text="{Binding AppVersion}" FontSize="16" FontWeight="SemiBold" Foreground="#F8FAFC" />
                    <TextBlock Text="How insights are computed" FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding InsightMethodology}" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" />
                    <TextBlock Text="What's new" FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,6,0,0" />
                    <ItemsControl ItemsSource="{Binding ChangelogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#B6C2D9" TextWrapping="Wrap" Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
